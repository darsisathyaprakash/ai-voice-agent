# Voice AI Agent Environment Configuration
# Copy to .env and fill in values

# ── Application ──
APP_NAME=Voice AI Agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Server ──
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://voiceai:voiceai_pass@localhost:5432/voiceai_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Cache (Redis) ──
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=1800
REDIS_CACHE_TTL=300

# ── OpenAI / LLM ──
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=10

# ── Speech-to-Text (Whisper) ──
STT_MODEL_SIZE=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# ── Text-to-Speech (Edge TTS) ──
TTS_DEFAULT_VOICE_EN=en-US-AriaNeural
TTS_DEFAULT_VOICE_HI=hi-IN-SwaraNeural
TTS_DEFAULT_VOICE_TE=te-IN-ShrutiNeural

# ── WebSocket ──
WS_MAX_MESSAGE_SIZE=1048576
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# ── Latency Targets (ms) ──
TARGET_STT_LATENCY_MS=150
TARGET_LLM_LATENCY_MS=200
TARGET_TTS_LATENCY_MS=100
TARGET_TOTAL_LATENCY_MS=450

# ── Campaign System ──
CAMPAIGN_WORKER_INTERVAL=60
CAMPAIGN_MAX_CONCURRENT=5
CAMPAIGN_MAX_RETRIES=3

# ── Node.js Orchestrator ──
NODE_PORT=3000
BACKEND_URL=http://localhost:8000
BACKEND_WS_URL=ws://localhost:8000
